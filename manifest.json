{
  "manifest_version": 3,
  "name": "AWS SSO Redirect",
  "description": "Automatically redirects AWS Console sign-in to your IAM Identity Center (SSO) portal.",
  "version": "1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "webNavigation"],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
